# Environment Configuration for Winning Products MVP
# Copy this file to .env and modify values as needed

# Environment mode
ENVIRONMENT=development

# CORS - which frontend origins can access this API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Database path (SQLite)
DATABASE_PATH=products.db

# eBay Browse API credentials (Phase 2C auto-discovery)
# Leave blank during development — the collector returns stub data without them.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
