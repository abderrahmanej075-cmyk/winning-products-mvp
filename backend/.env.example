# Environment Configuration for Winning Products MVP
# Copy this file to .env and modify values as needed

# Environment mode
ENVIRONMENT=development

# CORS - which frontend origins can access this API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Database path (SQLite)
DATABASE_PATH=products.db

# eBay Browse API credentials (Phase 2C auto-discovery)
# Leave blank during development — the collector returns stub data without them.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
# true  → API errors silently fall back to stub data (safe for dev/staging)
# false → API errors surface as HTTP 500 (recommended for production alerting)
EBAY_FALLBACK_TO_STUB=true

# eBay official connector live-mode gate (Phase 3A)
# Live calls are never made unless EBAY_LIVE_ENABLED=true AND credentials are set.
EBAY_ENVIRONMENT=sandbox
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_LIVE_ENABLED=false

# eBay production readiness gates (Phase 3C) — do not set until ready to test
# production. Production calls remain disabled in code regardless of these
# values; this phase only adds visibility into readiness, not the ability to go live.
EBAY_PRODUCTION_CLIENT_ID=
EBAY_PRODUCTION_CLIENT_SECRET=
EBAY_PRODUCTION_READY=false

# TikTok Ads Intelligence (stub mode works without any of these)
#
# TIKTOK_API_PROVIDER controls which live endpoint shape is used.
# Allowed values:
#   placeholder            (default) — stub always returned; no live calls attempted.
#                          TikTok for Business API has no product search endpoint.
#   commercial_content_api — TikTok Commercial Content API (official).
#                            Base URL: https://open.tiktokapis.com
#                            Endpoint: POST /v2/research/adlib/ad/query/
#                            Auth: Authorization: Bearer {token}
#                            Requires research.adlib.basic scope.
#                            Status becomes pending_access until TikTok approves access.
#                            App: Zaryotech Product Discovery (org: Zaryotech).
#                            Support ticket submitted 2026-07-05 — awaiting TikTok response.
#   mock                   — user-controlled local/test HTTP server at TIKTOK_API_BASE_URL.
#   third_party            — paid ad-intelligence platform (Minea, Pipiads, BigSpy, etc.)
#                            Set TIKTOK_API_BASE_URL to the provider's base URL.
#
# TIKTOK_API_TOKEN:    API key / Bearer token for the configured provider.
# TIKTOK_API_BASE_URL: Provider base URL (required for mock and third_party).
# TIKTOK_FALLBACK_TO_STUB: true → API errors fall back to stub silently.
TIKTOK_API_PROVIDER=commercial_content_api
TIKTOK_API_TOKEN=
TIKTOK_API_BASE_URL=
TIKTOK_FALLBACK_TO_STUB=true

# CJ Dropshipping API (stub mode works without these)
#
# CJ_API_TOKEN:    Access Token from CJ Dropshipping dashboard.
#                  How to obtain:
#                    1. Register a free account at cjdropshipping.com
#                    2. Go to Account → Open API → Generate API Key
#                    3. Call POST /v1/authentication/getAccessToken with your API Key
#                       to receive an Access Token (TTL: 180 days per current CJ docs).
#                    4. Refresh before expiry via
#                       POST /v1/authentication/refreshAccessToken (Refresh Token TTL: 180 days).
#                    Note: repeated calls to getAccessToken within 24 h return the same
#                    cached token. A new token is issued only after 24 h or logout.
#                  Set CJ_API_TOKEN to the Access Token value directly.
#
# CJ_API_BASE_URL: API base URL. Default: https://developers.cjdropshipping.com/api2.0
#                  Leave blank to use the default.
#
# CJ_FALLBACK_TO_STUB: true  → API errors fall back to stub data silently (recommended).
#                      false → API errors surface as HTTP errors (useful for debugging).
#
# NOTE: sellPrice in /v1/product/list is the dropshipper cost (supplier_cost), confirmed from
#       live API. retail_price is None in live mode — suggestSellPrice is not in the list
#       endpoint. Full margin scoring requires enrichment via /v1/product/query (detail endpoint).
CJ_API_TOKEN=
CJ_REFRESH_TOKEN=
CJ_TOKEN_EXPIRES_AT=
CJ_REFRESH_TOKEN_EXPIRES_AT=
CJ_API_BASE_URL=
CJ_FALLBACK_TO_STUB=true
